<Window x:Class="RobloxMultiInstance.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roblox Multi-Instance"
        Width="440" SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#14121C"
        FontFamily="Segoe UI"
        Foreground="#EDEBF2">

    <Border Padding="28,24">
        <StackPanel>
            <TextBlock Text="Roblox Multi-Instance"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Lets you run more than one Roblox client at a time."
                       Foreground="#A79FC0" FontSize="13" Margin="0,0,0,18"/>

            <!-- Status pill -->
            <Border x:Name="StatusPill" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="12" Height="12"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="StatusText" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Shown only when we couldn't claim the lock (Roblox running) -->
            <StackPanel x:Name="FixPanel" Visibility="Collapsed" Margin="0,0,0,4">
                <TextBlock TextWrapping="Wrap" Foreground="#F4A38A" FontSize="12.5" Margin="0,0,0,10"
                           Text="Roblox is already running, so the lock can't be claimed. Close every Roblox window (and the second one that just launched), then click Retry."/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ForceCloseBtn" Content="Force-close all Roblox"
                            Height="34" Padding="12,0" Cursor="Hand" Margin="0,0,8,0"
                            Background="#3A2230" Foreground="#FFD9E2" BorderThickness="0"
                            FontSize="12.5" Click="ForceClose_Click"/>
                    <Button x:Name="RetryBtn" Content="Retry"
                            Height="34" Padding="18,0" Cursor="Hand"
                            Background="#7C5CFF" Foreground="White" BorderThickness="0"
                            FontSize="12.5" FontWeight="SemiBold" Click="Retry_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Steps -->
            <StackPanel x:Name="StepsPanel" Margin="0,8,0,0">
                <TextBlock TextWrapping="Wrap" Foreground="#C9C3DC" FontSize="13" Margin="0,0,0,6">
                    <Run Text="1." FontWeight="Bold"/>
                    <Run Text="Close ALL Roblox windows before this shows green."/>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="#C9C3DC" FontSize="13" Margin="0,0,0,6">
                    <Run Text="2." FontWeight="Bold"/>
                    <Run Text="Keep this window open."/>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="#C9C3DC" FontSize="13" Margin="0,0,0,6">
                    <Run Text="3." FontWeight="Bold"/>
                    <Run Text="Now launch Roblox as many times as you want — each client stays open."/>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="#C9C3DC" FontSize="13" Margin="0,0,0,0">
                    <Run Text="4." FontWeight="Bold"/>
                    <Run Text="Closing this window turns multi-instance back off."/>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
